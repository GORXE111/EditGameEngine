{
  "version": 3,
  "cmakeMinimumRequired": { "major": 3, "minor": 24, "patch": 0 },
  "configurePresets": [
    {
      "name": "default",
      "displayName": "VS2022 x64 (default)",
      "description": "Visual Studio generator; auto-locates VS2022 even at D:\\VS2022 via vswhere",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build/default",
      "cacheVariables": {
        "CMAKE_CXX_STANDARD": "20",
        "CMAKE_POLICY_VERSION_MINIMUM": "3.5"
      }
    },
    {
      "name": "ninja",
      "displayName": "Ninja x64 (needs VS dev env)",
      "description": "Faster iterative builds. Run from a VS x64 dev shell or after vcvarsall x64.",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_CXX_STANDARD": "20",
        "CMAKE_POLICY_VERSION_MINIMUM": "3.5"
      }
    }
  ],
  "buildPresets": [
    { "name": "default", "configurePreset": "default", "configuration": "Debug" },
    { "name": "ninja", "configurePreset": "ninja" }
  ],
  "testPresets": [
    {
      "name": "default",
      "configurePreset": "default",
      "configuration": "Debug",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "ninja",
      "configurePreset": "ninja",
      "output": { "outputOnFailure": true }
    }
  ]
}
